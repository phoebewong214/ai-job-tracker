# Rename this file to .env and fill in your values.
# Never commit .env to GitHub — it's already in .gitignore.

# 1. Notion integration token
#    → https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2. Your Notion database ID
#    → Open your database in browser; the ID is the 32-char string in the URL
#      e.g. https://notion.so/yourworkspace/DATABASE_ID?v=...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 3. Gemini API key
#    → https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
